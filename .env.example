# Server
PORT=3001
DATABASE_PATH=./data/app.db
# Optional explicit CORS allowlist origin, e.g. https://your-site.netlify.app
CORS_ORIGIN=

# Provider
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# xAI / Grok
XAI_API_KEY=
XAI_MODEL=grok-4.20-beta-latest-non-reasoning

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_API_KEY=

# LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=

# Frontend (Vite)
# Leave empty for same-origin local development.
# Set to your Fly backend URL on Netlify production.
VITE_API_BASE_URL=
